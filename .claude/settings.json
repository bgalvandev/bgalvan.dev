{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm run dev)",
      "Bash(pnpm run build)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run test)",
      "Bash(pnpm run test:watch)",
      "Bash(pnpm run format)",
      "Bash(pnpm run format:check)",
      "Bash(pnpm run dead-code)",
      "Bash(pnpm run dupes)",
      "Bash(pnpm run check)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git fetch *)",
      "Bash(git merge-base *)",
      "Bash(git rev-parse *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(gh pr view *)",
      "Bash(gh pr checks *)"
    ]
  }
}
